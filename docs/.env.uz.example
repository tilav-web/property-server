# ============================================================================
# Uzbekistan (uybos.uz) production .env shabloni
# ----------------------------------------------------------------------------
# Bu faylni server'ga /home/property/server/.env nomi bilan ko'chiring va
# qiymatlarni to'ldiring. <PLACEHOLDER> qismlarini almashtiring.
# ============================================================================

# ============================================================================
# COUNTRY / REGION (UZ)
# ============================================================================
COUNTRY=UZ
DEFAULT_CURRENCY=UZS
DEFAULT_LANGUAGE=uz
SUPPORTED_LANGUAGES=uz,ru,en
DEFAULT_MAP_CENTER=41.2995,69.2401
DEFAULT_MAP_ZOOM=12

# ============================================================================
# Advertise (UZ)
# ============================================================================
ADVERTISE_DAILY_PRICE=20000
ADVERTISE_CURRENCY=UZS

# Premium upgrade
PREMIUM_PRICE=50000
PREMIUM_DURATION_DAYS=30

# ============================================================================
# CORE
# ============================================================================
PORT=3000
CLIENT_URL=https://uybos.uz
SERVER_URL=https://api.uybos.uz
NODE_ENV=production

# !!! Tasodifiy 64+ belgili string yarating: openssl rand -hex 32
JWT_SECRET=<RANDOM_64_CHARS>
ADMIN_JWT_SECRET=<BOSHQA_RANDOM_64_CHARS>

# MongoDB - Docker compose ichida ishlamoqda (container nomi: mongo)
MONGODB_URL=mongodb://mongo:27017/property

# ============================================================================
# AUTO ADMIN SEED - server birinchi marta ishga tushganda yaratiladi
# (agar admin yo'q bo'lsa). Keyin .env dagi parolni o'zgartirsangiz,
# yangi admin yaratilmaydi (mavjud bo'lsa skip qilinadi).
# ============================================================================
ADMIN_EMAIL=admin@uybos.uz
ADMIN_PASSWORD=<KUCHLI_PAROL_KIRITING>
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

# ============================================================================
# EMAIL (Gmail SMTP)
# ============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=shavqiddintilovov0@gmail.com
EMAIL_PASSWORD=<gmail app password>
DEFAULT_FROM=shavqiddintilovov0@gmail.com

# ============================================================================
# OAUTH
# ============================================================================
# Google Web (browser redirect flow)
GOOGLE_CLIENT_ID=272504579818-24576pupoipa1jimj881i9u7ov43618q.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<google secret>
GOOGLE_CALLBACK_URL=https://api.uybos.uz/users/auth/google/callback

# Google Mobile (iOS + Android client ID lar vergul orqali)
# Mobile dasturchi keyinroq qo'shadi
GOOGLE_MOBILE_CLIENT_IDS=

# Facebook (ishlatilmaydi - bo'sh qoldiring yoki olib tashlang)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=

# Apple (kelajakda)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=

# ============================================================================
# AI (OpenAI - property search uchun)
# ============================================================================
OPENAI_API_KEY=<sk-proj-...>

# ============================================================================
# DIGITAL OCEAN SPACES (rasm/video saqlash)
# ============================================================================
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=amaar-property
DO_SPACES_KEY=<do spaces key>
DO_SPACES_SECRET=<do spaces secret>
DO_SPACES_CDN_URL=https://amaar-property.sgp1.cdn.digitaloceanspaces.com

# ============================================================================
# SMS PROVIDER (UZ - Eskiz)
# ============================================================================
SMS_PROVIDER=eskiz
ESKIZ_API_URL=https://notify.eskiz.uz/api
ESKIZ_EMAIL=system@ats-systems.net
ESKIZ_PASSWORD=<eskiz password>
ESKIZ_DEFAULT_FROM=4546
ESKIZ_TEST_MODE=0

# ============================================================================
# PAYMENT (UZ - Payme)
# Hozircha sandbox - production'ga o'tishda PAYME_TEST_MODE=0 va
# PAYME_CHECKOUT_URL=https://checkout.paycom.uz
# ============================================================================
PAYMENT_PROVIDER=payme
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_CHECKOUT_URL=https://test.paycom.uz
PAYME_TEST_MODE=1
PAYME_ALLOWED_IPS=

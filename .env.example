# ============================================================================
# COUNTRY / REGION
# ----------------------------------------------------------------------------
# Loyiha bitta kod baza bilan ko'p mamlakatga (Malaysia, Uzbekistan) deploy
# qilinadi. Server qaysi mamlakat uchun ishlayotganini shu yerdan biladi.
#
# COUNTRY               - ISO 3166-1 alpha-2 (UZ, MY)
# DEFAULT_CURRENCY      - ISO 4217 kod (MYR, UZS, USD, ...)
# DEFAULT_LANGUAGE      - uz, ru, en, ms
# SUPPORTED_LANGUAGES   - vergul orqali ro'yxat (uz,ru,en yoki ms,en)
# DEFAULT_MAP_CENTER    - "lat,lng" (masalan: "41.2995,69.2401" Toshkent;
#                         "3.139,101.6869" Kuala Lumpur)
# DEFAULT_MAP_ZOOM      - Yandex/Google map default zoom (12 ga yaqin)
# ============================================================================
COUNTRY = UZ
DEFAULT_CURRENCY = UZS
DEFAULT_LANGUAGE = uz
SUPPORTED_LANGUAGES = uz,ru,en
DEFAULT_MAP_CENTER = 41.2995,69.2401
DEFAULT_MAP_ZOOM = 12

# Reklama (advertise) narxi va valyutasi mamlakatga qarab farqlanadi.
# ADVERTISE_CURRENCY bo'sh qoldirsa - DEFAULT_CURRENCY ishlatiladi.
ADVERTISE_DAILY_PRICE = 20000
ADVERTISE_CURRENCY =

# ============================================================================
# PAYMENT PROVIDER
# ----------------------------------------------------------------------------
# PAYMENT_PROVIDER  - payme (UZ) | click (UZ, kelajak) | none (MY - to'lov yo'q)
#
# Payme uchun:
#   PAYME_MERCHANT_ID    - Payme dashboard'dan (Merchant cabinet ID)
#   PAYME_SECRET_KEY     - Webhook Basic auth uchun (Paycom:<KEY>)
#   PAYME_CHECKOUT_URL   - Sandbox: https://test.paycom.uz
#                          Production: https://checkout.paycom.uz
#   PAYME_TEST_MODE      - 1 = IP whitelist o'chiriladi (sandbox/ngrok uchun)
#                          0 = faqat Payme rasmiy IP'lariga ruxsat
#   PAYME_ALLOWED_IPS    - Bo'sh qoldirilsa default Payme IP'lari ishlatiladi
#                          (185.234.113.1-15). Override uchun vergul orqali.
#
# Webhook URL (Payme dashboard'iga kiritish):
#   Production: https://amaar.uz/api/payme/webhook
#   Local dev:  https://<ngrok-id>.ngrok.io/api/payme/webhook
# ============================================================================
PAYMENT_PROVIDER = payme

PAYME_MERCHANT_ID =
PAYME_SECRET_KEY =
PAYME_CHECKOUT_URL = https://test.paycom.uz
PAYME_TEST_MODE = 1
PAYME_ALLOWED_IPS =

# ----------------------------------------------------------------------------
# PREMIUM (Property is_premium upgrade)
# ----------------------------------------------------------------------------
# PREMIUM_PRICE          - DEFAULT_CURRENCY birligida (so'm UZ uchun)
# PREMIUM_DURATION_DAYS  - Premium qancha kun davom etadi (default: 30)
# ----------------------------------------------------------------------------
PREMIUM_PRICE = 50000
PREMIUM_DURATION_DAYS = 30

# ============================================================================
# SMS PROVIDER
# ----------------------------------------------------------------------------
# SMS_PROVIDER  - eskiz (Uzb) | none (Malaysia - SMS yo'q, faqat Google
#                 OAuth + email/parol orqali auth)
#
# Malaysia uchun: SMS_PROVIDER=none qo'ying va ESKIZ_* env'larini bo'sh
# qoldiring yoki olib tashlang.
# ============================================================================
SMS_PROVIDER = eskiz

# Eskiz (Uzb) - faqat SMS_PROVIDER=eskiz bo'lsa kerak
ESKIZ_API_URL=https://notify.eskiz.uz/api
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_DEFAULT_FROM=4546
# Test rejimi: 1 bo'lsa Eskiz approved sample SMS yuboriladi (sandbox uchun)
ESKIZ_TEST_MODE=0

# ============================================================================
# CORE
# ============================================================================
PORT = 3000
CLIENT_URL = http://localhost:5173
NODE_ENV =

JWT_SECRET = 2f9c3b7d8e1a4f6b9d0e2f4a7c8b1d3e
MONGODB_URL = mongodb://127.0.0.1:27017/property

# BullMQ (like/save counter navbati) shu Redis'ni ishlatadi. Docker
# compose'da REDIS_URL=redis://redis:6379 bo'ladi.
REDIS_URL = redis://127.0.0.1:6379

# ============================================================================
# MAIL
# ============================================================================
EMAIL_HOST =
EMAIL_PORT =
EMAIL_USERNAME =
EMAIL_PASSWORD =
DEFAULT_FROM =

# ============================================================================
# OAUTH
# ============================================================================
# Google OAuth
# - GOOGLE_CLIENT_ID: web client (browser redirect flow uchun)
# - GOOGLE_CALLBACK_URL: web flow callback
# - GOOGLE_MOBILE_CLIENT_IDS: mobile (iOS + Android) client IDs vergul orqali
#   Server idToken'da aud field shu ID lardan biri bo'lishini tekshiradi.
#   Mobile dasturchi Google Cloud Console'da iOS/Android uchun alohida
#   OAuth client yaratadi va shu ID'larni beradi.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/users/auth/google/callback
GOOGLE_MOBILE_CLIENT_IDS=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/users/auth/facebook/callback

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3000/api/users/auth/apple/callback

# ============================================================================
# STORAGE - DigitalOcean Spaces (yoki har qanday S3-compatible)
# ============================================================================
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=amaar-property
DO_SPACES_KEY=DO00...
DO_SPACES_SECRET=...
DO_SPACES_CDN_URL=https://amaar-property.sgp1.cdn.digitaloceanspaces.com

# ============================================================================
# FIREBASE / FCM PUSH NOTIFICATIONS
# ----------------------------------------------------------------------------
# Firebase Console → Project Settings → Service Accounts → Generate new key
# Natijada yuklab olingan JSON faylning mazmunini bir qatorga qo'yib bering.
#
# Agar bo'sh qoldirilsa — FCM push notificationlar o'chiriladi,
# lekin ilovaning qolgan funksionalligi ishlayveradi.
#
# Misol:
#   FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"my-app",...}
# ============================================================================
FIREBASE_SERVICE_ACCOUNT=
